#version 430 core

#define FLOAT_MAX 3.4028235e+38
#define FLOAT_MIN -3.4028235e+38
#define EPSILON 0.001
#define PI              3.1415926
#define INF             114514.0
#define SIZE_BVHNODE    4

layout (local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(rgba32f, binding = 0) uniform image2D imgOutput;
uniform samplerCube SamplerEnvironment;

// Un array invece di N sampler2D: l'indice della texture dipende dal materiale colpito,
// che varia da raggio a raggio. Indicizzare un array di sampler con un indice non
// "dynamically uniform" e' undefined behavior; il layer di un sampler2DArray no.
uniform sampler2DArray AlbedoTextures;

// Nodo BVH a 4 vie in layout SoA (128 byte): le AABB dei 4 figli sono impacchettate
// per componente, cosi' lo slab test dei 4 box si fa con poche operazioni vec4 invece
// di 4 test scalari. Deve combaciare bit-per-bit con BVH4Node lato C++ (BVHBuilder.h).
struct BVH4Node {
    vec4 bminx; vec4 bminy; vec4 bminz;  // min.{x,y,z} dei 4 figli
    vec4 bmaxx; vec4 bmaxy; vec4 bmaxz;  // max.{x,y,z} dei 4 figli
    ivec4 child;  // interno: indice nodo | foglia: primo indice in TriIndex
    ivec4 count;  // 0 = interno, >0 = foglia con N triangoli, <0 = slot vuoto
};

struct Ray {
    vec3 Origin;
    vec3 Direction;
    float t;
};

struct Sphere {
    vec4 Position;
    float Mat;
};

struct Quad {
	vec4 PositionLLC;
	vec4 U;
	vec4 V;
	float MaterialIndex;
	float Width;
	float Height;
};

struct CubeInfo {
    vec4 BoundsMin;
    vec4 BoundsMax;
    float FirstQuad;
};

struct MeshInfo {
    mat4 Transform;
    mat4 InvTransform;
    vec4 BoundsMin;   // AABB in world space
    vec4 BoundsMax;
    vec4 LocalMin;
    vec4 LocalMax;
    float FirstTriangle;
    float NumTriangles;
    float MaterialIndex;
    float RootNode;   // radice del BLAS di questa mesh
};

// Posizioni e normali sono in due buffer separati: il loop caldo del BVH tocca
// solo le posizioni (48B), le normali servono una sola volta sull'hit finale.
struct TrianglePosition {
    vec4 A;
    vec4 B;
    vec4 C;
};

struct TriangleNormal {
    vec4 NormalA;
    vec4 NormalB;
    vec4 NormalC;
};

// uv nel .xy; anche questo buffer e' freddo, letto solo sull'hit finale
struct TriangleUV {
    vec4 A;
    vec4 B;
    vec4 C;
};

struct Material {
    vec4 Color;
    float Roughness;
    float SpecularProbability;
    float RefractionRatio;
    float EmissiveStrenght;
    vec4 EmissiveColor;
	vec4 SpecularColor;
	float RefractionProbability;
	float RefractionRoughness;
	vec4 RefractionColor;
    float AlbedoTexture; // layer nel sampler2DArray, < 0 = nessuna texture
    float Checker;       // 0 = off, 1 = scacchiera UV, 2 = scacchiera world-space
    float CheckerScale;  // celle per unita' di UV (o di spazio, se world-space)
    float NoiseType;       // 0 = off, 1 = perlin, 2 = turbolenza, 3 = marmo
    float NoiseScale;      // frequenza in celle per unita' di mondo
    float NoiseBlend;      // 0 = albedo di base, 1 = solo rumore
    float NoiseOctaves;    // ottave della turbolenza
    float NoiseTurbulence; // peso della turbolenza nella fase del marmo
    vec4 NoiseColorA;
    vec4 NoiseColorB;
    float Metalness;     // 0 = dielettrico, 1 = metallo
    float SpecularTint;  // 0 = riflesso bianco, 1 = tinto verso base color (solo dielettrici)
};

struct HitInfo {
    float HitDistance;
    vec3 HitPosition;
    vec3 Normal;
    int ObjectIndex;
    int ObjectType;
    bool Inside;
    vec2 UV;
    int MaterialIndex; // materiale gia' risolto: per-triangolo sulle mesh, altrimenti dell'oggetto
};

Ray CalculateRayFromCamera(mat4 inverseProj, mat4 inverseView, vec3 cameraPos, vec2 ndc);
vec4 PerPixel(vec2 ndc);
vec3 BSDF(inout Ray ray, HitInfo hit, Material material, out bool isRefractive);
HitInfo TraceRay(Ray ray);
HitInfo HandleHit(Ray ray, float hitDistance, int index, int objType, bool insideHit, float u, float v);
HitInfo NoHit();
bool HitSphere(Ray ray, Sphere sphere, out float t1, out float t2);
float HitQuad(Ray ray, Quad quad);
float HitTriangle(Ray ray, vec3 A, vec3 B, vec3 C, out float u, out float v);
bool HitBoundingBox(Ray ray, vec3 boxMin, vec3 boxMax, vec3 position);
float FresnelSchlick(float n1, float n2, vec3 normal, vec3 incident, float f0, float f90);
vec3 GetNormal(Quad quad, vec3 surfacePosition);
uint GetPCGHash(inout uint seed);
float GetRandomFloat();
vec3 GetRandomVector(uint seed);

float hitAABB(Ray ray, vec3 invDir, vec3 bmin, vec3 bmax);
float hitBVH(inout Ray ray, int rootNode, out int hitTriIndex, out float outU, out float outV);
float TraceMeshes(inout Ray ray, out int hitTriIndex, out float outU, out float outV);
vec3 BvhHeatColor(float t);
vec3 SampleAlbedo(Material material, vec2 uv, vec3 position);
vec2 SphereUV(vec3 normal);
float PerlinNoise(vec3 p);
float Turbulence(vec3 p, int octaves);
float NoiseValue(Material material, vec3 position);

int rootNodeIndex = 0;

// contatore di nodi BVH visitati (test AABB) usato dal debugger BVH
int gNodeVisits = 0;

